// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountOwnerType {
  PERSONAL
  COMPANY
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  IMPLEMENTED
}

model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  username            String    @unique
  displayName         String?
  displayNameChanged  Boolean   @default(false)
  firstName           String?
  lastName            String?
  avatarUrl           String?
  createdAt           DateTime  @default(now())

  // Relations
  gameProfile         GameProfile?
  accounts            BankAccount[]
  companies           Company[]
  suggestions         Suggestion[]
  votes               SuggestionVote[]

  @@map("users")
}

model GameProfile {
  id              String      @id @default(uuid())
  userId          String      @unique
  homeLocationId  String
  totalBalance    BigInt      @default(0)
  createdAt       DateTime    @default(now())

  // Relations
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeLocation    MapLocation @relation(fields: [homeLocationId], references: [id])

  @@map("game_profiles")
}

model BankAccount {
  id              String           @id @default(uuid())
  ownerId         String
  ownerType       AccountOwnerType
  companyId       String?
  balance         BigInt           @default(0)
  accountNumber   String           @unique
  createdAt       DateTime         @default(now())

  // Relations
  owner           User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  company         Company?         @relation(fields: [companyId], references: [id])
  sentTransactions     Transaction[] @relation("FromAccount")
  receivedTransactions Transaction[] @relation("ToAccount")

  @@map("bank_accounts")
}

model Transaction {
  id              String      @id @default(uuid())
  fromAccountId   String
  toAccountId     String
  amount          BigInt
  label           String?
  createdAt       DateTime    @default(now())

  // Relations
  fromAccount     BankAccount @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount       BankAccount @relation("ToAccount", fields: [toAccountId], references: [id])

  @@map("transactions")
}

model Company {
  id                String      @id @default(uuid())
  ownerId           String
  name              String
  objective         String      @db.VarChar(200)
  description       String      @db.VarChar(500)
  locationId        String
  capitalAccountId  String      @unique
  createdAt         DateTime    @default(now())

  // Relations
  owner             User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  location          MapLocation @relation(fields: [locationId], references: [id])
  capitalAccount    BankAccount @relation(fields: [capitalAccountId], references: [id])

  @@map("companies")
}

model MapLocation {
  id                    String        @id @default(uuid())
  name                  String
  lat                   Float
  lng                   Float
  unlocked              Boolean       @default(false)
  requiredUsersToUnlock Int

  // Relations
  residents             GameProfile[]
  companies             Company[]

  @@map("map_locations")
}

model Suggestion {
  id            String           @id @default(uuid())
  authorId      String
  title         String
  description   String
  status        SuggestionStatus @default(PENDING)
  upvotes       Int              @default(0)
  createdAt     DateTime         @default(now())

  // Relations
  author        User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes         SuggestionVote[]

  @@map("suggestions")
}

model SuggestionVote {
  id            String    @id @default(uuid())
  userId        String
  suggestionId  String
  createdAt     DateTime  @default(now())

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion    Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@unique([userId, suggestionId])
  @@map("suggestion_votes")
}

// For future market/stock exchange feature
model PriceHistory {
  id          String   @id @default(uuid())
  itemType    String   // 'RESOURCE', 'COMPANY_SHARE', 'ITEM'
  itemId      String   // ID of the item being tracked
  price       BigInt   // Price in centimes at this point in time
  volume      Int?     // Trading volume (optional)
  recordedAt  DateTime @default(now())

  @@index([itemType, itemId, recordedAt])
  @@map("price_history")
}
