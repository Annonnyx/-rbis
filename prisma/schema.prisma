generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  firstName     String?   @map("first_name")
  lastName      String?   @map("last_name")
  identifier    String    @unique @default(cuid())
  nameChangedAt DateTime? @map("name_changed_at")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  accounts      Account[]
  sessions      Session[]
  bankAccounts  BankAccount[]
  location      UserLocation?
  business      Business?
  suggestions   Suggestion[]
  stockTrades   StockTrade[]
  votes         Vote[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model BankAccount {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        AccountType
  name        String
  balance     Decimal  @default(0) @db.Decimal(15, 2)
  currency    String   @default("Ø")
  isMain      Boolean  @default(false) @map("is_main")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  business    Business? @relation(fields: [businessId], references: [id])
  businessId  String?  @map("business_id")

  @@map("bank_accounts")
}

model Transaction {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  type        TransactionType
  amount      Decimal  @db.Decimal(15, 2)
  description String?
  relatedAccountId String? @map("related_account_id")
  createdAt   DateTime @default(now()) @map("created_at")

  account     BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model UserLocation {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  lat       Decimal  @db.Decimal(10, 8)
  lng       Decimal  @db.Decimal(11, 8)
  address   String?
  cityId    String?  @map("city_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city      City?    @relation(fields: [cityId], references: [id])

  @@map("user_locations")
}

model City {
  id          String   @id @default(cuid())
  name        String
  nameEn      String?  @map("name_en")
  nameFr      String?  @map("name_fr")
  nameDe      String?  @map("name_de")
  nameEs      String?  @map("name_es")
  lat         Decimal  @db.Decimal(10, 8)
  lng         Decimal  @db.Decimal(11, 8)
  isUnlocked  Boolean  @default(false) @map("is_unlocked")
  unlockThreshold Int  @default(0) @map("unlock_threshold")
  createdAt   DateTime @default(now()) @map("created_at")

  locations   UserLocation[]
  businesses  Business[]

  @@map("cities")
}

model Business {
  id          String   @id @default(cuid())
  userId      String   @unique @map("user_id")
  name        String
  description String?
  objective   String?
  product     String?
  service     String?
  cityId      String?  @map("city_id")
  capital     Decimal  @default(0) @db.Decimal(15, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  city        City?    @relation(fields: [cityId], references: [id])
  accounts    BankAccount[]
  stock       Stock?
  products    Product[]
  sales       Sale[]

  @@map("businesses")
}

model Suggestion {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  title       String
  description String   @db.Text
  type        SuggestionType
  status      SuggestionStatus @default(PENDING)
  votes       Int      @default(0)
  implementedAt DateTime? @map("implemented_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  votesList   Vote[]

  @@map("suggestions")
}

model Vote {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  suggestionId String   @map("suggestion_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@unique([userId, suggestionId])
  @@map("votes")
}

model Stock {
  id          String   @id @default(cuid())
  businessId  String   @unique @map("business_id")
  symbol      String   @unique
  totalShares Int      @default(1000) @map("total_shares")
  availableShares Int  @default(1000) @map("available_shares")
  currentPrice Decimal @default(1.00) @db.Decimal(15, 2) @map("current_price")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  trades      StockTrade[]
  history     StockHistory[]

  @@map("stocks")
}

model StockTrade {
  id          String   @id @default(cuid())
  stockId     String   @map("stock_id")
  buyerId     String   @map("buyer_id")
  sellerId    String?  @map("seller_id")
  quantity    Int
  price       Decimal  @db.Decimal(15, 2)
  total       Decimal  @db.Decimal(15, 2)
  type        TradeType
  createdAt   DateTime @default(now()) @map("created_at")

  stock       Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)
  buyer       User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@map("stock_trades")
}

model StockHistory {
  id          String   @id @default(cuid())
  stockId     String   @map("stock_id")
  price       Decimal  @db.Decimal(15, 2)
  timestamp   DateTime @default(now())

  stock       Stock    @relation(fields: [stockId], references: [id], onDelete: Cascade)

  @@map("stock_history")
}

model Product {
  id          String   @id @default(cuid())
  businessId  String   @map("business_id")
  name        String
  description String?
  price       Decimal  @db.Decimal(15, 2)
  stock       Int      @default(0)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  sales       Sale[]

  @@map("products")
}

model Sale {
  id          String   @id @default(cuid())
  productId   String   @map("product_id")
  businessId  String   @map("business_id")
  quantity    Int
  unitPrice   Decimal  @db.Decimal(15, 2) @map("unit_price")
  totalAmount Decimal  @db.Decimal(15, 2) @map("total_amount")
  buyerName   String   @map("buyer_name")
  createdAt   DateTime @default(now()) @map("created_at")

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@map("sales")
}

model GlobalSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("global_settings")
}

enum AccountType {
  PERSONAL
  BUSINESS
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PAYMENT
  DIVIDEND
}

enum SuggestionType {
  FEATURE
  RULE
  EVENT
  ECONOMY
}

enum SuggestionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  IMPLEMENTED
}

enum TradeType {
  BUY
  SELL
}
