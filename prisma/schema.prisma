// ============================================
// prisma/schema.prisma
// Schéma de données Ørbis - Simulation socio-économique
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// ENUMS
// ============================================

enum AccountOwnerType {
  PERSONAL
  COMPANY
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
  IMPLEMENTED
}

enum MarketListingStatus {
  ACTIVE
  SOLD
  CANCELLED
}

// ============================================
// MODELS
// ============================================

/**
 * Utilisateur - Entité centrale du système
 * Auth gérée par Supabase, données profil ici
 */
model User {
  id                 String    @id @default(uuid())
  email              String    @unique
  username           String    @unique
  displayName        String?
  displayNameChanged Boolean   @default(false)
  firstName          String?
  lastName           String?
  avatarUrl          String?
  createdAt          DateTime  @default(now())

  // Relations
  gameProfile   GameProfile?
  accounts      BankAccount[]
  companies     Company[]
  suggestions   Suggestion[]
  votes         SuggestionVote[]
  shareBuys     ShareTransaction[] @relation("Buyer")
  shareSells    ShareTransaction[] @relation("Seller")
  portfolio     SharePortfolio[]
  marketListings MarketListing[] @relation("Seller")
  skills        UserSkill[]
  employments   Employment[] @relation("Employee")

  @@map("users")
}

/**
 * Profil de jeu - Lié 1:1 à User
 * Contient les données spécifiques au gameplay
 */
model GameProfile {
  id             String      @id @default(uuid())
  userId         String      @unique
  homeLocationId String
  createdAt      DateTime    @default(now())

  // Relations
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeLocation MapLocation @relation(fields: [homeLocationId], references: [id])

  @@map("game_profiles")
}

/**
 * Compte bancaire - PERSONAL ou COMPANY
 * Tous les montants sont stockés en centimes (BigInt)
 */
model BankAccount {
  id            String           @id @default(uuid())
  ownerId       String
  ownerType     AccountOwnerType
  companyId     String?
  balance       BigInt           @default(0)
  accountNumber String           @unique
  createdAt     DateTime         @default(now())

  // Relations
  owner                User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  sentTransactions     Transaction[] @relation("FromAccount")
  receivedTransactions Transaction[] @relation("ToAccount")
  capitalCompany       Company?      @relation("CompanyCapital")

  @@map("bank_accounts")
}

/**
 * Transaction entre comptes
 * Les labels sont optionnels
 */
model Transaction {
  id            String      @id @default(uuid())
  fromAccountId String
  toAccountId   String
  amount        BigInt
  label         String?
  createdAt     DateTime    @default(now())

  // Relations
  fromAccount BankAccount @relation("FromAccount", fields: [fromAccountId], references: [id], onDelete: Cascade)
  toAccount   BankAccount @relation("ToAccount", fields: [toAccountId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

/**
 * Entreprise créée par un utilisateur
 * Chaque entreprise a un compte capital dédié
 */
model Company {
  id               String   @id @default(uuid())
  ownerId          String
  name             String
  objective        String   @db.VarChar(200)
  description      String   @db.VarChar(500)
  locationId       String
  capitalAccountId String   @unique
  createdAt        DateTime @default(now())

  // Relations
  owner          User        @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  location       MapLocation @relation(fields: [locationId], references: [id])
  capitalAccount BankAccount @relation("CompanyCapital", fields: [capitalAccountId], references: [id])
  shareInfo      CompanyShare?
  transactions   ShareTransaction[]
  portfolio      SharePortfolio[]
  listings       MarketListing[]
  priceHistory   PriceHistory[]
  jobPostings    JobPosting[]
  employments    Employment[]

  @@map("companies")
}

/**
 * Localisation sur la carte du monde
 * Certaines sont débloquées selon le nombre d'utilisateurs
 */
model MapLocation {
  id                    String        @id @default(uuid())
  name                  String
  lat                   Float
  lng                   Float
  unlocked              Boolean       @default(false)
  requiredUsersToUnlock Int

  // Relations
  residents GameProfile[]
  companies Company[]

  @@map("map_locations")
}

/**
 * Suggestion faite par un utilisateur pour améliorer le jeu
 */
model Suggestion {
  id          String           @id @default(uuid())
  authorId    String
  title       String
  description String
  status      SuggestionStatus @default(PENDING)
  createdAt   DateTime         @default(now())

  // Relations
  author User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  votes  SuggestionVote[]

  @@map("suggestions")
}

/**
 * Vote sur une suggestion (table pivot avec contrainte unique)
 */
model SuggestionVote {
  id           String   @id @default(uuid())
  userId       String
  suggestionId String
  createdAt    DateTime @default(now())

  // Relations
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  suggestion Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)

  @@unique([userId, suggestionId])
  @@map("suggestion_votes")
}

// ============================================
// MODÈLES BOURSE & MARCHÉ FINANCIER
// ============================================

/**
 * Informations boursières d'une entreprise
 * Une seule entrée par entreprise cotée
 */
model CompanyShare {
  id               String   @id @default(uuid())
  companyId        String   @unique
  totalShares      Int      @default(0)
  availableShares  Int      @default(0)
  currentPrice       BigInt   @default(1000) // centimes d'Orbe, min ◎ 0,01 (1 centime)
  lastPriceUpdate  DateTime @default(now())
  isListed         Boolean  @default(false)
  createdAt        DateTime @default(now())

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_shares")
}

/**
 * Transaction d'actions entre joueurs ou IPO
 * Historique immuable de toutes les transactions
 */
model ShareTransaction {
  id            String   @id @default(uuid())
  buyerId       String
  sellerId      String?  // null si achat initial à l'entreprise (IPO)
  companyId     String
  quantity      Int
  pricePerShare BigInt   // prix au moment de la transaction
  totalAmount   BigInt
  createdAt     DateTime @default(now())

  // Relations
  buyer   User    @relation("Buyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller  User?   @relation("Seller", fields: [sellerId], references: [id], onDelete: SetNull)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("share_transactions")
}

/**
 * Portfolio d'actions d'un utilisateur
 * Table pivot avec quantité et prix moyen d'achat
 */
model SharePortfolio {
  id              String @id @default(uuid())
  userId          String
  companyId       String
  quantity        Int    @default(0)
  averageBuyPrice BigInt @default(0) // prix moyen pondéré d'achat

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@map("share_portfolios")
}

/**
 * Annonce de vente sur le marché secondaire
 * Permet aux joueurs de vendre leurs actions à d'autres joueurs
 */
model MarketListing {
  id          String              @id @default(uuid())
  sellerId    String
  companyId   String
  quantity    Int
  askingPrice BigInt              // prix demandé par action
  status      MarketListingStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  expiresAt   DateTime?           // expiration optionnelle
  soldAt      DateTime?           // date de vente

  // Relations
  seller  User    @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("market_listings")
}

/**
 * Historique des prix d'une entreprise
 * Une entrée à chaque changement de prix ou toutes les heures
 */
model PriceHistory {
  id         String   @id @default(uuid())
  companyId  String
  price      BigInt
  recordedAt DateTime @default(now())
  volume     Int      @default(0) // volume de transactions à ce prix

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, recordedAt])
  @@map("price_history")
}

// ============================================
// MODÈLES SYSTÈME D'EMPLOI
// ============================================

enum JobStatus {
  OPEN
  CLOSED
}

enum EmploymentStatus {
  ACTIVE
  TERMINATED
}

/**
 * Catégorie de compétences (référence)
 */
model SkillCategory {
  id   String @id @default(uuid())
  name String @unique
  icon String @default("⭐")

  // Relations
  userSkills UserSkill[]
  jobPostings JobPosting[]

  @@map("skill_categories")
}

/**
 * Compétence d'un utilisateur avec niveau et XP
 */
model UserSkill {
  id               String @id @default(uuid())
  userId           String
  skillCategoryId  String
  level            Int    @default(1)
  experience       Int    @default(0)

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  skillCategory SkillCategory @relation(fields: [skillCategoryId], references: [id], onDelete: Cascade)

  @@unique([userId, skillCategoryId])
  @@map("user_skills")
}

/**
 * Offre d'emploi publiée par une entreprise
 */
model JobPosting {
  id             String    @id @default(uuid())
  companyId      String
  title          String
  description    String
  skillCategoryId String
  minSkillLevel  Int       @default(1)
  salaryPerDay   BigInt
  maxEmployees   Int       @default(1)
  status         JobStatus @default(OPEN)
  createdAt      DateTime  @default(now())

  // Relations
  company       Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skillCategory SkillCategory @relation(fields: [skillCategoryId], references: [id], onDelete: Cascade)
  applications  Employment[]

  @@map("job_postings")
}

/**
 * Contrat d'emploi
 */
model Employment {
  id             String            @id @default(uuid())
  employeeId     String
  companyId      String
  jobPostingId   String
  startedAt      DateTime          @default(now())
  salaryPerDay   BigInt
  status         EmploymentStatus  @default(ACTIVE)
  lastPaidAt     DateTime?
  terminatedAt   DateTime?
  terminationReason String?

  // Relations
  employee      User            @relation("Employee", fields: [employeeId], references: [id], onDelete: Cascade)
  company       Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobPosting    JobPosting      @relation(fields: [jobPostingId], references: [id], onDelete: Cascade)
  payments      SalaryPayment[]

  @@unique([employeeId, status], name: "unique_active_employment")
  @@map("employments")
}

/**
 * Paiement de salaire
 */
model SalaryPayment {
  id           String   @id @default(uuid())
  employmentId String
  amount       BigInt
  paidAt       DateTime @default(now())
  daysPaid     Int      @default(1)

  // Relations
  employment Employment @relation(fields: [employmentId], references: [id], onDelete: Cascade)

  @@map("salary_payments")
}
